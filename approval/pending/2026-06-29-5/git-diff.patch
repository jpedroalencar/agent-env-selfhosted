+++++++            metadata = ArtifactMetadata(
+++++++                title=title,
+++++++                persona=persona,
+++++++                created_date=date_str,
+++++++                status=status,
+++++++                tags=tags,
+++++++                freshness_days=freshness_days,
+++++++                summary=summary,
