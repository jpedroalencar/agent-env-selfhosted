+++++++            if len(cells) < 8:
+++++++                continue
+++++++
+++++++            date_str, title, persona, status, tags_str, freshness_str, summary, path = (
+++++++                cells[0],
+++++++                cells[1],
+++++++                cells[2],
+++++++                cells[3],
+++++++                cells[4],
+++++++                cells[5],
+++++++                cells[6][:100],
+++++++                cells[7],
+++++++            )
