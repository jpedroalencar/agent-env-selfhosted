+++++++        summary, and path using deterministic lexical scoring.
+++++++        """
+++++++        # Mode-only selection: preserve existing behavior.
+++++++        if title is None:
+++++++            matches = list(artifacts_map.values())
+++++++            matches.sort(key=lambda m: m.created_date, reverse=True)
+++++++            return matches
+++++++
